# Egg's Apple ID (used to filter messages in chat.db)
EGG_APPLE_ID=egg@example.com

# User's phone number (for sending messages)
EGG_USER_PHONE=+15551234567

# BlueBubbles server (optional — falls back to AppleScript)
BLUEBUBBLES_URL=http://localhost:1234
BLUEBUBBLES_PASSWORD=

# Brain command: "claude" or "codex"
EGG_BRAIN=claude

# Anthropic API key (used for image captioning via vision API)
ANTHROPIC_API_KEY=sk-ant-...

# Path to egg source repo (needed for self-modification tasks)
EGG_CODE_DIR=/Users/you/egg

# Path to chat.db (optional — defaults to ~/Library/Messages/chat.db)
# CHAT_DB=/Users/you/Library/Messages/chat.db

# Image generation (optional — enables [IMAGE: ...] responses)
# IMAGE_GEN_API_KEY=sk-...
# IMAGE_GEN_PROVIDER=openai   # only "openai" (DALL-E 3) is supported right now

# Oura Ring integration (optional — enables good morning nudges with sleep/readiness data)
# Option A: Personal Access Token (simplest — get one at https://cloud.ouraring.com/personal-access-tokens)
# OURA_TOKEN=...
# Option B: OAuth2 app (set these + run `egg oura:auth`)
# OURA_CLIENT_ID=...
# OURA_CLIENT_SECRET=...
